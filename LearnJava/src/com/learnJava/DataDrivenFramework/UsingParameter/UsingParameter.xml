<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
        📊 About verbose="2"
        This DOES NOT affect report generation.
        It only controls console logging detail.
        Value	Meaning
        0	Minimal logs
        1	Default
        2	Detailed
        10	Very detailed-->
<suite name="ValidUserName" verbose="10">
    <test name="Test Case 1">
        <parameter name="userName1" value="Admin"/>
        <parameter name="password1" value="12345"/>
        <classes>
            <class name="com.learnJava.DataDrivenFramework.UsingParameter.ValidUserName"/>
        </classes>
    </test>
    <test name="Test Case 2">
        <parameter name="userName2" value="Admin123"/>
        <parameter name="password2" value="admin123"/>
        <classes>
            <class name="com.learnJava.DataDrivenFramework.UsingParameter.ValidPassword"/>
        </classes>
    </test>
    <test name="Test Case 3">
        <parameter name="userName3" value="Admin"/>
        <parameter name="password3" value="admin123"/>
        <classes>
            <class name="com.learnJava.DataDrivenFramework.UsingParameter.BothValidData"/>
        </classes>
    </test>
    <test name="Test Case 4">
        <parameter name="userName3" value="Admin123"/>
        <parameter name="password3" value="admin12345"/>
        <classes>
            <class name="com.learnJava.DataDrivenFramework.UsingParameter.BothInvalidData"/>
        </classes>
    </test>
</suite>